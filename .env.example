# App server
PORT=3000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Security
JWT_SECRET=replace_with_a_long_random_secret
ACCESS_EXPIRY=15m
REFRESH_EXPIRY_MS=604800000

# Database
DATABASE_URL=mysql://root:your_password@127.0.0.1:3306/WalletDB

# Email verification
APP_BASE_URL=http://localhost:3000
EMAIL_FROM=no-reply@wallet.local
EMAIL_VERIFY_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_REQUIRED=true

# SMTP (optional for local dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password

# Rate limiting (optional overrides)
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=120
AUTH_LOGIN_RATE_WINDOW_MS=900000
AUTH_LOGIN_RATE_MAX=15
WALLET_RATE_WINDOW_MS=60000
WALLET_RATE_MAX=120

# Auth policy knobs (optional overrides)
MIN_PASSWORD_LENGTH=8
LOGIN_ATTEMPT_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=900000
LOGIN_MAX_ATTEMPTS=5
